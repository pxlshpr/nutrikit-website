            120
          ],
          "alignItems": "center",
          "children": [
            {
              "type": "text",
              "id": "ahI72",
              "fill": "$accent-purple",
              "content": "SMART TARGETS",
              "fontFamily": "Inter",
              "fontSize": 11,
              "fontWeight": "700",
              "letterSpacing": 3
            },
            {
              "type": "text",
              "id": "XTJnM",
              "fill": "$text-primary",
              "textGrowth": "fixed-width",
              "width": 900,
              "content": "How NutriKit builds personalized\nnutrient targets for your body",
              "textAlign": "center",
              "fontFamily": "Sora",
              "fontSize": 48,
              "fontWeight": "bold",
              "letterSpacing": -1.5
            },
            {
              "type": "text",
              "id": "7d2Ww",
              "fill": "$text-secondary",
              "textGrowth": "fixed-width",
              "width": 720,
              "content": "Most nutrition apps give you the same targets as everyone else. NutriKit calculates individual recommended ranges for every nutrient — drawing from peer-reviewed research papers and institutional guidelines — based on who you actually are.",
              "lineHeight": 1.6,
              "textAlign": "center",
              "fontFamily": "Inter",
              "fontSize": 18,
              "fontWeight": "normal"
            }
          ]
        },
        {
          "type": "frame",
          "id": "8KpJS",
          "name": "Article Body",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 48,
          "padding": [
            0,
            340
          ],
          "children": [
            {
              "type": "frame",
              "id": "w4IFx",
              "name": "Section - The Problem",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 20,
              "children": [
                {
                  "type": "text",
                  "id": "bHDor",
                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "The problem with generic targets",
                  "fontFamily": "Sora",
                  "fontSize": 32,
                  "fontWeight": "bold",
                  "letterSpacing": -0.5
                },
                {
                  "type": "text",
                  "id": "ttbU2",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Most nutrition apps use a single set of recommended daily values — the same ones printed on food labels. These are based on a 2,000-calorie diet for a generic adult. They don't account for your age, sex, body weight, lean mass, activity level, or whether you're pregnant or breastfeeding.\n\nThe result? A 22-year-old female athlete and a 55-year-old sedentary male get the same protein target, the same iron target, the same vitamin D target. That's not personalization — it's a lookup table.\n\nNutriKit takes a fundamentally different approach. Instead of one fixed number per nutrient, it calculates a recommended range — a lower bound and an upper bound — using the best available evidence for your specific profile. And every recommendation shows its source, so you always know where the numbers come from.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "PRcf2",
              "name": "Section - How It Works",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 20,
              "children": [
                {
                  "type": "text",
                  "id": "Zn9PY",
                  "fill": "$text-primary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "How your targets are calculated",
                  "fontFamily": "Sora",
                  "fontSize": 32,
                  "fontWeight": "bold",
                  "letterSpacing": -0.5
                },
                {
                  "type": "text",
                  "id": "ySiqB",
                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "When you set up NutriKit, you provide your biological sex, date of birth, body weight, and optionally your body fat percentage or lean body mass. If you're pregnant or breastfeeding, that's captured too.\n\nFrom these inputs, NutriKit calculates personalized targets for every tracked nutrient. The calculation isn't a simple formula — it's a decision tree that selects the right recommendation source for each nutrient based on your profile.",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            },
