                  "fill": "$text-secondary",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "NutriKit doesn't use one formula for everyone. It evaluates what data is available and selects the most accurate method it can. The hierarchy, from most to least accurate:",
                  "lineHeight": 1.7,
                  "fontFamily": "Inter",
